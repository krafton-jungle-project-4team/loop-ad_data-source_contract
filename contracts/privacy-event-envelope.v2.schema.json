{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop-ad.org/contracts/privacy-event-envelope.v2.schema.json",
  "title": "LoopAd Privacy Event Envelope v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "project_id",
    "schema_version",
    "event_id",
    "event_name",
    "event_time",
    "source",
    "subject_id",
    "identity_namespace",
    "identity_key_version",
    "consent",
    "properties"
  ],
  "properties": {
    "envelope_version": {
      "const": "privacy-event.v2"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "event_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "enum": [
        "private_connector",
        "browser_sdk"
      ]
    },
    "subject_id": {
      "type": "string",
      "pattern": "^sub_[0-9a-f]{64}$"
    },
    "identity_namespace": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "identity_key_version": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 128
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "policy_version",
        "purpose_ids"
      ],
      "properties": {
        "status": {
          "const": "granted"
        },
        "policy_version": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "purpose_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
          }
        }
      }
    },
    "properties": {
      "type": "object"
    }
  }
}
