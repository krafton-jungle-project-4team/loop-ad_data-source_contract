POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_DB=loopad
POSTGRES_USER=loopad
POSTGRES_PASSWORD=loopad
POSTGRES_IMAGE=postgres:16-alpine

CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=18123
CLICKHOUSE_NATIVE_PORT=19000
CLICKHOUSE_DATABASE=loopad
CLICKHOUSE_USER=loopad_app
CLICKHOUSE_PASSWORD=loopad_local_password
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24.12-alpine

KAFKA_CLUSTER_ID=loopadlocalcluster000001
KAFKA_EXTERNAL_PORT=9094
KAFKA_SCRAM_USERNAME=event-collector
KAFKA_SCRAM_PASSWORD=event-collector-local-password

LOOPAD_POSTGRES_URL=postgresql://loopad:loopad@localhost:15432/loopad
LOOPAD_CLICKHOUSE_URL=http://localhost:18123
LOOPAD_CLICKHOUSE_USERNAME=loopad_app
LOOPAD_CLICKHOUSE_PASSWORD=loopad_local_password
LOOPAD_KAFKA_BOOTSTRAP_BROKERS=localhost:9094
LOOPAD_KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
LOOPAD_KAFKA_SASL_MECHANISM=SCRAM-SHA-512
